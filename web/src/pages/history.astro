---
import Layout from '../components/Layout.astro';
import { getRecentJobs, getClients } from '../lib/api';

const url = Astro.url;
const page = parseInt(url.searchParams.get('page') ?? '1', 10);
const filterClientId = url.searchParams.get('client_id') ?? '';
const filterStatus = url.searchParams.get('status') ?? '';

const PER_PAGE = 50;

let jobs = [];
let clients = [];
let fetchError = '';

try {
  [jobs, clients] = await Promise.all([
    getRecentJobs({
      client_id: filterClientId || undefined,
      status: filterStatus || undefined,
      page,
      per_page: PER_PAGE,
    }),
    getClients(),
  ]);
} catch (e: any) {
  fetchError = e.message;
}

// Group jobs by date
function groupByDate(jobs) {
  const groups: Record<string, typeof jobs> = {};
  for (const job of jobs) {
    const date = job.started_at.slice(0, 10);
    if (!groups[date]) groups[date] = [];
    groups[date].push(job);
  }
  return groups;
}

const grouped = groupByDate(jobs);
const dates = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

function clientName(id: string): string {
  return clients.find(c => c.id === id)?.name ?? id.slice(0, 8);
}

function statusClass(status: string) {
  if (status === 'success') return 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400';
  if (status === 'failed') return 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400';
  if (status === 'pending') return 'bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400';
  return 'bg-gray-100 dark:bg-slate-600 text-gray-500 dark:text-slate-300';
}

function buildUrl(params: Record<string, string | number>) {
  const p = new URLSearchParams();
  const merged = {
    client_id: filterClientId,
    status: filterStatus,
    page: String(page),
    ...params,
  };
  for (const [k, v] of Object.entries(merged)) {
    if (v) p.set(k, String(v));
  }
  return `/history?${p.toString()}`;
}
---

<Layout title="History">
  <div class="flex items-center justify-between mb-6 flex-wrap gap-4">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-slate-100">Update History</h1>
  </div>

  <!-- Filters -->
  <form method="get" action="/history" class="flex items-center gap-3 mb-6 flex-wrap">
    <select
      name="client_id"
      class="rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
    >
      <option value="">All clients</option>
      {clients.map(c => (
        <option value={c.id} selected={filterClientId === c.id}>{c.name}</option>
      ))}
    </select>

    <select
      name="status"
      class="rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
    >
      <option value="">All statuses</option>
      <option value="success" selected={filterStatus === 'success'}>Success</option>
      <option value="failed" selected={filterStatus === 'failed'}>Failed</option>
      <option value="pending" selected={filterStatus === 'pending'}>Pending</option>
    </select>

    <button
      type="submit"
      class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors"
    >
      Filter
    </button>

    {(filterClientId || filterStatus) && (
      <a
        href="/history"
        class="px-4 py-2 rounded-lg border border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-300 text-sm hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
      >
        Clear
      </a>
    )}
  </form>

  {fetchError && (
    <div class="mb-6 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 text-sm">
      <strong>Error:</strong> {fetchError}
    </div>
  )}

  {dates.length > 0 ? (
    <div class="space-y-8">
      {dates.map(date => (
        <div>
          <h2 class="text-sm font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-3">
            <span class="date-header" data-date={date}>{date}</span>
          </h2>
          <div class="bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
              <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
                {grouped[date].map(job => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/30 transition-colors">
                    <td class="px-4 py-3">
                      <span class={`inline-block text-xs px-2 py-0.5 rounded-full font-medium ${statusClass(job.status)}`}>
                        {job.status}
                      </span>
                    </td>
                    <td class="px-4 py-3">
                      <a
                        href={`/clients/${job.client_id}`}
                        class="text-indigo-600 dark:text-indigo-400 hover:underline text-xs font-medium"
                      >
                        {clientName(job.client_id)}
                      </a>
                    </td>
                    <td class="px-4 py-3 font-medium text-gray-900 dark:text-slate-100">
                      {job.container_name}
                    </td>
                    <td class="px-4 py-3 text-gray-500 dark:text-slate-400 text-xs truncate max-w-xs" title={job.image}>
                      {job.image}
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-400 dark:text-slate-500">
                      <span class="job-ts" data-ts={job.started_at}>{job.started_at}</span>
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-400 dark:text-slate-500">
                      {job.completed_at ? (
                        <span class="job-ts" data-ts={job.completed_at}>{job.completed_at}</span>
                      ) : '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}

      <!-- Pagination -->
      <div class="flex items-center justify-between pt-2">
        <span class="text-sm text-gray-500 dark:text-slate-400">
          Page {page} · {jobs.length} results
        </span>
        <div class="flex items-center gap-2">
          {page > 1 && (
            <a
              href={buildUrl({ page: page - 1 })}
              class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-slate-600 text-sm text-gray-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              ← Prev
            </a>
          )}
          {jobs.length === PER_PAGE && (
            <a
              href={buildUrl({ page: page + 1 })}
              class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-slate-600 text-sm text-gray-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              Next →
            </a>
          )}
        </div>
      </div>
    </div>
  ) : !fetchError ? (
    <div class="text-center py-24">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-slate-100 mb-2">No update history</h2>
      <p class="text-gray-500 dark:text-slate-400">Trigger updates from the client page to see history here.</p>
    </div>
  ) : null}
</Layout>

<script>
  // Localise timestamps
  document.querySelectorAll<HTMLElement>('.job-ts').forEach(el => {
    const ts = el.dataset.ts;
    if (!ts) return;
    try {
      el.textContent = new Intl.DateTimeFormat(undefined, {
        dateStyle: 'short', timeStyle: 'short',
      }).format(new Date(ts));
    } catch { /* leave */ }
  });

  document.querySelectorAll<HTMLElement>('.date-header').forEach(el => {
    const d = el.dataset.date;
    if (!d) return;
    try {
      el.textContent = new Intl.DateTimeFormat(undefined, { dateStyle: 'long' }).format(new Date(d + 'T00:00:00'));
    } catch { /* leave */ }
  });
</script>
