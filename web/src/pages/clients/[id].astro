---
import Layout from '../../components/Layout.astro';
import ContainerGrid from '../../components/ContainerGrid.astro';
import UpdateJobStream from '../../components/UpdateJobStream.astro';
import { getClient, getContainers } from '../../lib/api';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/clients');
}

let client = null;
let containers = [];
let fetchError = '';

try {
  client = await getClient(id);
  containers = await getContainers(id, true);
} catch (e: any) {
  fetchError = e.message;
}

const apiBase =
  import.meta.env.PUBLIC_API_URL ||
  process.env.PUBLIC_API_URL ||
  'http://localhost:3101';
---

<Layout title={client?.name ?? 'Client'}>
  <div class="mb-4">
    <a href="/clients" class="text-sm text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200">← Back to clients</a>
  </div>

  {fetchError && (
    <div class="mb-6 p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-amber-800 dark:text-amber-200">Having trouble reaching the API</p>
          <p class="text-sm text-amber-700 dark:text-amber-300 mt-1">Check that the DockUp API is running and reachable, then review the API container logs for details.</p>
          <button
            onclick="window.location.reload()"
            class="mt-3 px-3 py-1.5 text-xs font-medium rounded-lg bg-amber-100 dark:bg-amber-800/40 text-amber-800 dark:text-amber-200 hover:bg-amber-200 dark:hover:bg-amber-800/60 transition-colors"
          >
            Refresh
          </button>
        </div>
      </div>
    </div>
  )}

  {client && !client.connected && (
    <div class="mb-4 px-4 py-3 rounded-lg bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 flex items-center gap-2 text-sm text-yellow-800 dark:text-yellow-300">
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
      </svg>
      <span>
        Agent is disconnected — container data may be stale.
        {client.last_seen && (
          <> Last seen: <span class="last-seen-ts font-mono text-xs" data-ts={client.last_seen}>{client.last_seen}</span></>
        )}
        {!client.last_seen && <> Never connected.</>}
      </span>
    </div>
  )}

  {client && (
    <>
      <!-- Client header -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border-l-4 border border-gray-200 dark:border-slate-700 shadow-sm p-6 mb-6"
        style={`border-left-color: ${client.color}`}
      >
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span
                class={`inline-block w-2.5 h-2.5 rounded-full ${client.connected ? 'bg-green-400' : 'bg-gray-300 dark:bg-slate-600'}`}
              ></span>
              <h1 class="text-xl font-bold text-gray-900 dark:text-slate-100">{client.name}</h1>
              <span class="text-sm text-gray-400 dark:text-slate-500">{client.connected ? 'Online' : 'Offline'}</span>
            </div>
            <p class="text-sm text-gray-500 dark:text-slate-400 font-mono">{client.host}</p>
            {client.agent_version && (
              <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">Agent v{client.agent_version}</p>
            )}
          </div>

          <div class="flex items-center gap-2">
            <button
              id="edit-client-btn"
              class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors"
            >
              Edit
            </button>
            <button
              id="delete-client-btn"
              class="px-3 py-1.5 rounded-lg text-sm font-medium border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
              data-client-id={client.id}
              data-client-name={client.name}
            >
              Delete
            </button>
          </div>
        </div>

        <!-- Edit form (hidden by default) -->
        <div id="edit-form" class="hidden mt-4 pt-4 border-t border-gray-100 dark:border-slate-700">
          <form id="client-edit-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-slate-400 mb-1">Name</label>
              <input
                name="name"
                type="text"
                value={client.name}
                class="w-full rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-slate-400 mb-1">Color</label>
              <input
                name="color"
                type="color"
                value={client.color}
                class="h-10 w-20 rounded-lg border border-gray-300 dark:border-slate-600 cursor-pointer"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-slate-400 mb-1">Compose file path</label>
              <input
                name="compose_file_path"
                type="text"
                value={client.compose_file_path ?? ''}
                class="w-full rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-slate-400 mb-1">Agent update mode</label>
              <select
                name="agent_update_mode"
                class="w-full rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
              >
                <option value="manual" selected={client.agent_update_mode === 'manual'}>Manual</option>
                <option value="auto" selected={client.agent_update_mode === 'auto'}>Auto</option>
              </select>
            </div>
            <div class="sm:col-span-2 flex items-center gap-2">
              <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors">
                Save
              </button>
              <button type="button" id="cancel-edit-btn" class="px-4 py-2 rounded-lg border border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-300 text-sm hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                Cancel
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Containers -->
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100 mb-4">Containers</h2>
        {containers.length > 0 ? (
          <ContainerGrid containers={containers} clientId={client.id} />
        ) : (
          <div class="text-center py-16 bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-700 mb-3">
              <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
              </svg>
            </div>
            <p class="text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">No running containers found on this host</p>
            <p class="text-xs text-gray-500 dark:text-slate-400 max-w-sm mx-auto">If this looks wrong, check that the agent is connected and the Docker socket is accessible.</p>
          </div>
        )}
      </div>

      <UpdateJobStream clientId={client.id} />
    </>
  )}
</Layout>

<script define:vars={{ apiBase, clientId: id }}>
  (function() {
    document.querySelectorAll('.last-seen-ts').forEach(function(el) {
      const ts = el.dataset.ts;
      if (!ts) return;
      try {
        el.textContent = new Intl.DateTimeFormat(undefined, { dateStyle: 'short', timeStyle: 'short' }).format(new Date(ts));
      } catch(e) { /* leave raw */ }
    });
    const editBtn = document.getElementById('edit-client-btn');
    const editForm = document.getElementById('edit-form');
    const cancelBtn = document.getElementById('cancel-edit-btn');
    const clientEditForm = document.getElementById('client-edit-form');
    const deleteBtn = document.getElementById('delete-client-btn');

    editBtn?.addEventListener('click', () => {
      editForm.classList.toggle('hidden');
    });

    cancelBtn?.addEventListener('click', () => {
      editForm.classList.add('hidden');
    });

    clientEditForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(clientEditForm);
      const data = {
        name: fd.get('name'),
        color: fd.get('color'),
        compose_file_path: fd.get('compose_file_path') || null,
        agent_update_mode: fd.get('agent_update_mode'),
      };
      try {
        const res = await fetch(`${apiBase}/api/clients/${clientId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(await res.text());
        window.location.reload();
      } catch(err) {
        alert(`Failed to update client: ${err.message}`);
      }
    });

    deleteBtn?.addEventListener('click', async () => {
      const name = deleteBtn.dataset.clientName;
      if (!confirm(`Delete client "${name}"? This will also remove all container and job records.`)) return;
      try {
        const res = await fetch(`${apiBase}/api/clients/${clientId}`, { method: 'DELETE' });
        if (!res.ok && res.status !== 204) throw new Error(await res.text());
        window.location.href = '/clients';
      } catch(err) {
        alert(`Failed to delete: ${err.message}`);
      }
    });
  })();
</script>
