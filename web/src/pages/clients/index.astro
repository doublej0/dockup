---
import Layout from '../../components/Layout.astro';
import { getClients, getContainers } from '../../lib/api';

let clients = [];
let fetchError = '';
const publicApiUrl = import.meta.env.PUBLIC_API_URL || process.env.PUBLIC_API_URL || 'http://localhost:3101';

try {
  clients = await getClients();
} catch (e: any) {
  fetchError = e.message;
}

const summaries: Record<string, { running: number; updatesAvailable: number; total: number }> = {};

await Promise.all(
  clients.map(async (client) => {
    try {
      const containers = await getContainers(client.id, true);
      summaries[client.id] = {
        running: containers.filter(c => c.status === 'running').length,
        updatesAvailable: containers.filter(c => c.update_available).length,
        total: containers.length,
      };
    } catch {
      summaries[client.id] = { running: 0, updatesAvailable: 0, total: 0 };
    }
  })
);
---

<Layout title="Clients">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-slate-100">Clients</h1>
    <div class="flex items-center gap-2">
      <button
        id="check-all-btn"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-indigo-200 dark:border-indigo-700 text-indigo-600 dark:text-indigo-400 text-sm font-medium hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Check all
      </button>
      <a
        href="/clients/new"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors"
      >
        + Add Client
      </a>
    </div>
  </div>

  {fetchError && (
    <div class="mb-6 p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-amber-800 dark:text-amber-200">Having trouble reaching the API</p>
          <p class="text-sm text-amber-700 dark:text-amber-300 mt-1">Check that the DockUp API is running and reachable, then review the API container logs for details.</p>
          <p class="text-xs text-amber-600 dark:text-amber-400 mt-2 font-mono">API should be available at {publicApiUrl}</p>
          <button
            onclick="window.location.reload()"
            class="mt-3 px-3 py-1.5 text-xs font-medium rounded-lg bg-amber-100 dark:bg-amber-800/40 text-amber-800 dark:text-amber-200 hover:bg-amber-200 dark:hover:bg-amber-800/60 transition-colors"
          >
            Refresh
          </button>
        </div>
      </div>
    </div>
  )}

  {clients.length > 0 ? (
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 dark:bg-slate-700/50 border-b border-gray-200 dark:border-slate-700">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Name</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Host</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Status</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Containers</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Updates</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Agent</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 dark:text-slate-300">Last Seen</th>
            <th class="text-right px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
          {clients.map(client => {
            const s = summaries[client.id] ?? { running: 0, updatesAvailable: 0, total: 0 };
            return (
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/30 transition-colors" data-client-id={client.id}>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span
                      class="w-3 h-3 rounded-sm flex-shrink-0"
                      style={`background-color: ${client.color}`}
                    ></span>
                    <a href={`/clients/${client.id}`} class="font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                      {client.name}
                    </a>
                  </div>
                </td>
                <td class="px-4 py-3 text-gray-500 dark:text-slate-400 font-mono text-xs">{client.host}</td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center gap-1.5 text-xs px-2 py-1 rounded-full font-medium ${
                    client.connected
                      ? 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400'
                      : 'bg-gray-100 dark:bg-slate-600 text-gray-500 dark:text-slate-300'
                  }`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${client.connected ? 'bg-green-500' : 'bg-gray-400'}`}></span>
                    {client.connected ? 'Online' : 'Offline'}
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-700 dark:text-slate-300">
                  {s.running} / {s.total}
                </td>
                <td class="px-4 py-3" id={`updates-${client.id}`}>
                  {client.updates_available > 0 ? (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-medium">
                      {client.updates_available} available
                    </span>
                  ) : (
                    <span class="text-xs text-gray-400 dark:text-slate-500">—</span>
                  )}
                </td>
                <td class="px-4 py-3 text-xs text-gray-400 dark:text-slate-500">
                  {client.agent_version ? `v${client.agent_version}` : '—'}
                </td>
                <td class="px-4 py-3 text-xs text-gray-400 dark:text-slate-500">
                  <span class="last-seen-ts" data-ts={client.last_seen ?? ''}>{client.last_seen ?? 'Never'}</span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/clients/${client.id}`}
                    class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline"
                  >
                    Manage →
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  ) : !fetchError ? (
    <div class="text-center py-24">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-indigo-50 dark:bg-indigo-900/30 mb-4">
        <svg class="w-8 h-8 text-indigo-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-slate-100 mb-2">No clients configured</h2>
      <p class="text-gray-500 dark:text-slate-400 mb-6 max-w-sm mx-auto">Add a host to get started monitoring containers and tracking updates.</p>
      <a href="/clients/new" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition-colors">
        + Add Client
      </a>
    </div>
  ) : null}
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('.last-seen-ts').forEach(el => {
    const ts = el.dataset.ts;
    if (!ts) { el.textContent = 'Never'; return; }
    try {
      el.textContent = new Intl.DateTimeFormat(undefined, {
        dateStyle: 'short', timeStyle: 'short',
      }).format(new Date(ts));
    } catch { /* leave */ }
  });

  function renderUpdatesCell(count: number): string {
    if (count > 0) {
      return `<span class="text-xs px-2 py-0.5 rounded-full bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-medium">${count} available</span>`;
    }
    return `<span class="text-xs text-gray-400 dark:text-slate-500">—</span>`;
  }

  async function pollUpdates() {
    try {
      const res = await fetch('/api/proxy?path=/api/clients');
      if (!res.ok) return;
      const clients: { id: string; updates_available: number }[] = await res.json();
      for (const client of clients) {
        const cell = document.getElementById(`updates-${client.id}`);
        if (cell) {
          cell.innerHTML = renderUpdatesCell(client.updates_available);
        }
      }
    } catch { /* ignore network errors */ }
  }

  setInterval(pollUpdates, 30_000);

  // Check all button
  const checkAllBtn = document.getElementById('check-all-btn') as HTMLButtonElement | null;
  if (checkAllBtn) {
    checkAllBtn.addEventListener('click', async () => {
      checkAllBtn.disabled = true;
      checkAllBtn.textContent = 'Checking...';

      const clientIds = Array.from(
        document.querySelectorAll<HTMLElement>('tr[data-client-id]')
      ).map(row => row.dataset.clientId!);

      await Promise.allSettled(
        clientIds.map(id =>
          fetch(`/api/proxy?path=/api/clients/${id}/check-versions`, { method: 'POST' })
        )
      );

      setTimeout(() => window.location.reload(), 5000);
    });
  }
</script>
